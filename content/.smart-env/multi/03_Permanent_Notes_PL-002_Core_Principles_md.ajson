oom Charter","target":"PL-001 Project Loom Charter","line":18},{"title":"PL-003 Research Principles","target":"PL-003 Research Principles","line":22},{"title":"PL-001 Project Loom Charter","target":"PL-001 Project Loom Charter","line":44}],"metadata":{"type":"permanent-note","id":"PL-002","created":"2026-07-11","tags":[],"original_folder":"Archive"},"task_lines":[],"tasks":{},"codeblock_ranges":[],"key":"03 Permanent Notes/PL-002 Core Principles.md"},
